shell-integration = zsh
shell-integration-features = true

font-family = "FiraCode Nerd Font"
font-style = "Retina"
font-thicken = true

theme = "Firefly Traditional"
mouse-hide-while-typing = true
scrollback-limit = 50_000_000

copy-on-select = clipboard
app-notifications = true

unfocused-split-opacity = 1
split-divider-color = green

quick-terminal-position = center
quick-terminal-animation-duration = 0

keybind = super+r=reload_config

window-save-state = always
window-decoration = auto
window-padding-balance = true
window-inherit-font-size = true
window-colorspace = "display-p3"

app-notifications = no-clipboard-copy

cursor-style = block

keybind = ctrl+b>left=goto_split:left
keybind = ctrl+b>down=goto_split:bottom
keybind = ctrl+b>up=goto_split:top
keybind = ctrl+b>right=goto_split:right

keybind = ctrl+b>h=new_split:left
keybind = ctrl+b>j=new_split:down
keybind = ctrl+b>k=new_split:up
keybind = ctrl+b>l=new_split:right
keybind = ctrl+b>z=toggle_split_zoom

keybind = ctrl+b>n=next_tab
keybind = ctrl+b>p=previous_tab

keybind = ctrl+b>f=toggle_quick_terminal
